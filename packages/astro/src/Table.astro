---
type TableVariant = "default" | "striped" | "bordered";
type TableSize = "normal" | "compact";

interface Props {
	variant?: TableVariant;
	size?: TableSize;
	hover?: boolean;
	sticky?: boolean;
	/** Cap the wrapper's height so it scrolls internally — required for `sticky` to have a scrollport to stick within. Any CSS length. */
	maxHeight?: string;
	ariaLabel?: string;
	class?: string;
	/** Any other attribute (`id`, `title`, `data-*`, `aria-*`, …) passes through to the element. */
	[key: string]: unknown;
}

const {
	variant = "default",
	size = "normal",
	hover = false,
	sticky = false,
	maxHeight,
	ariaLabel,
	class: extra,
	...rest
} = Astro.props;
---

<xoji-table
	variant={variant}
	size={size}
	hover={hover ? "" : undefined}
	sticky={sticky ? "" : undefined}
	max-height={maxHeight || undefined}
	style={maxHeight ? `--xoji-table-max-height: ${maxHeight}` : undefined}
	aria-label={ariaLabel || undefined}
	class:list={["xoji-table-wrap", extra]}
	{...rest}
>
	<slot />
</xoji-table>

<script>
	import "@xoji/core/elements";
</script>
