{
	"$schema": "https://xript.dev/schema/mod/v0.7.json",
	"xript": "0.7",
	"name": "xoji-field-default",
	"version": "0.0.1",
	"title": "Xoji Field (default)",
	"description": "The built-in fill for the xoji Field component: the mod-zero markup and behavior every app inherits and may override.",
	"capabilities": ["xoji.component.field"],
	"entry": { "script": "mod.js", "format": "script" },
	"fills": {
		"component.field": [
			{
				"id": "field",
				"format": "text/html+jsml",
				"source": "field.html",
				"handlers": [
					{ "selector": ".xoji-field__input", "on": "input", "handler": "onInput" },
					{ "selector": ".xoji-field__input", "on": "change", "handler": "onChange" },
					{ "selector": "[data-action=\"clear\"]", "on": "click", "handler": "clear" },
					{ "selector": "[data-action=\"reveal\"]", "on": "click", "handler": "reveal" }
				]
			}
		]
	}
}
