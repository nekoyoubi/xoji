{
	"$schema": "https://xript.dev/schema/mod/v0.7.json",
	"xript": "0.7",
	"name": "xoji-checkbox-default",
	"version": "0.0.1",
	"title": "Xoji Checkbox (default)",
	"description": "The built-in fill for the xoji Checkbox component: the mod-zero markup and behavior every app inherits and may override.",
	"capabilities": ["xoji.component.checkbox"],
	"entry": { "script": "mod.js", "format": "script" },
	"fills": {
		"component.checkbox": [
			{
				"id": "checkbox",
				"format": "text/html+jsml",
				"source": "checkbox.html",
				"handlers": [{ "selector": ".xoji-checkbox__control", "on": "change", "handler": "toggle" }]
			}
		]
	}
}
