{
	"$schema": "https://xript.dev/schema/mod/v0.7.json",
	"xript": "0.7",
	"name": "xoji-accordion-default",
	"version": "0.0.1",
	"title": "Xoji Accordion (default)",
	"description": "The built-in fill for the xoji Accordion component: the mod-zero markup and behavior every app inherits and may override.",
	"capabilities": ["xoji.component.accordion"],
	"entry": { "script": "mod.js", "format": "script" },
	"fills": {
		"component.accordion": [
			{
				"id": "accordion",
				"format": "text/html+jsml",
				"source": "accordion.html",
				"handlers": [
					{ "selector": ".xoji-accordion__trigger", "on": "click", "handler": "toggleSection" },
					{ "selector": ".xoji-accordion__trigger", "on": "keydown", "handler": "navKeydown" }
				]
			}
		]
	}
}
