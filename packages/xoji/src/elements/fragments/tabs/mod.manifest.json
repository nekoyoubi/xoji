{
	"$schema": "https://xript.dev/schema/mod/v0.7.json",
	"xript": "0.7",
	"name": "xoji-tabs-default",
	"version": "0.0.1",
	"title": "Xoji Tabs (default)",
	"description": "The built-in fill for the xoji Tabs component: the mod-zero markup and behavior every app inherits and may override.",
	"capabilities": ["xoji.component.tabs"],
	"entry": { "script": "mod.js", "format": "script" },
	"fills": {
		"component.tabs": [
			{
				"id": "tabs",
				"format": "text/html+jsml",
				"source": "tabs.html",
				"handlers": [
					{ "selector": "[role=\"tab\"]", "on": "click", "handler": "selectTab" },
					{ "selector": "[role=\"tab\"]", "on": "keydown", "handler": "navKeydown" }
				]
			}
		]
	}
}
