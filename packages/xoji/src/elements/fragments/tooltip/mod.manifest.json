{
	"$schema": "https://xript.dev/schema/mod/v0.7.json",
	"xript": "0.7",
	"name": "xoji-tooltip-default",
	"version": "0.0.1",
	"title": "Xoji Tooltip (default)",
	"description": "The built-in fill for the xoji Tooltip component: the mod-zero markup and behavior every app inherits and may override.",
	"capabilities": ["xoji.component.tooltip"],
	"entry": { "script": "mod.js", "format": "script" },
	"fills": {
		"component.tooltip": [
			{
				"id": "tooltip",
				"format": "text/html+jsml",
				"source": "tooltip.html",
				"meta": {
					"tokens": [
						"--fg-0",
						"--font-sans",
						"--text-sm",
						"--weight-normal",
						"--leading-tight",
						"--surface-overlay",
						"--surface-overlay-border",
						"--border-thin",
						"--radius-sm",
						"--elevation-2",
						"--duration-fast",
						"--ease-standard",
						"--space-1",
						"--space-2",
						"--space-8"
					]
				}
			}
		]
	}
}
