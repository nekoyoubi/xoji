{
	"$schema": "https://xript.dev/schema/mod/v0.7.json",
	"xript": "0.7",
	"name": "xoji-text-default",
	"version": "0.0.1",
	"title": "Xoji Text (default)",
	"description": "The built-in fill for the xoji Text component: the mod-zero markup every app inherits and may override.",
	"capabilities": ["xoji.component.text"],
	"entry": { "script": "mod.js", "format": "script" },
	"fills": {
		"component.text": [
			{
				"id": "text",
				"format": "text/html+jsml",
				"source": "text.html",
				"meta": {
					"tokens": [
						"--font-sans",
						"--font-mono",
						"--text-xs",
						"--text-sm",
						"--text-body",
						"--text-lg",
						"--weight-normal",
						"--weight-medium",
						"--weight-semibold",
						"--weight-bold",
						"--leading-tight",
						"--leading-normal",
						"--leading-loose",
						"--fg-0",
						"--fg-2",
						"--fg-3",
						"--accent-text"
					]
				}
			}
		]
	}
}
