{
	"$schema": "https://xript.dev/schema/mod/v0.7.json",
	"xript": "0.7",
	"name": "xoji-panel-default",
	"version": "0.0.1",
	"title": "Xoji Panel (default)",
	"description": "The built-in fill for the xoji Panel component: the mod-zero markup and behavior every app inherits and may override.",
	"capabilities": ["xoji.component.panel"],
	"entry": { "script": "mod.js", "format": "script" },
	"fills": {
		"component.panel": [
			{
				"id": "panel",
				"format": "text/html+jsml",
				"source": "panel.html",
				"handlers": [{ "selector": ".xoji-panel__toggle", "on": "click", "handler": "togglePanel" }],
				"meta": {
					"tokens": [
						"--bg-0",
						"--bg-1",
						"--border-thin",
						"--border-normal",
						"--border-thick",
						"--line",
						"--line-2",
						"--radius-lg",
						"--space-2",
						"--space-3",
						"--space-4",
						"--space-8",
						"--font-display",
						"--weight-semibold",
						"--text-sm",
						"--fg-1",
						"--fg-2",
						"--ring",
						"--state-hover",
						"--state-press",
						"--duration-fast",
						"--ease-standard",
						"--ease-emphasized"
					]
				}
			}
		]
	}
}
