{
	"$schema": "https://xript.dev/schema/mod/v0.7.json",
	"xript": "0.7",
	"name": "xoji-cluster-default",
	"version": "0.0.1",
	"title": "Xoji Cluster (default)",
	"description": "The built-in fill for the xoji Cluster component: the mod-zero markup every app inherits and may override.",
	"capabilities": ["xoji.component.cluster"],
	"entry": { "script": "mod.js", "format": "script" },
	"fills": {
		"component.cluster": [
			{
				"id": "cluster",
				"format": "text/html+jsml",
				"source": "cluster.html",
				"meta": {
					"tokens": [
						"--space-0",
						"--space-1",
						"--space-2",
						"--space-3",
						"--space-4",
						"--space-5",
						"--space-6",
						"--space-7",
						"--space-8"
					]
				}
			}
		]
	}
}
