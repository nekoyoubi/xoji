---
import FormGroup from "@xoji/astro/FormGroup.astro";
import Stack from "@xoji/astro/Stack.astro";
import Grid from "@xoji/astro/Grid.astro";
import Heading from "@xoji/astro/Heading.astro";
---

<Stack gap={6} class="demo">
	<section class="demo__group">
		<Heading level={3} size="sm" tone="muted">Wrapping any control</Heading>
		<Grid minColWidth="17rem" gap={5}>
			<FormGroup
				label="Display name"
				description="Shown next to your contributions."
				for="fg-name"
				required
			>
				<input id="fg-name" class="xoji-control" type="text" value="ada-l" />
			</FormGroup>
			<FormGroup label="Visibility" description="Who can find this project." for="fg-vis">
				<select id="fg-vis" name="fg-vis" class="xoji-control">
					<option selected>Public</option>
					<option>Unlisted</option>
					<option>Private</option>
				</select>
			</FormGroup>
		</Grid>
	</section>

	<section class="demo__group">
		<Heading level={3} size="sm" tone="muted">Validation</Heading>
		<Grid minColWidth="17rem" gap={5}>
			<FormGroup
				label="Slug"
				for="fg-slug"
				invalid
				error="That slug is already taken."
			>
				<input id="fg-slug" class="xoji-control" type="text" value="xoji" aria-invalid="true" />
			</FormGroup>
			<FormGroup
				label="Seat count"
				description="Billed monthly per seat."
				for="fg-seats"
				required
			>
				<input id="fg-seats" class="xoji-control" type="number" value="5" />
			</FormGroup>
		</Grid>
	</section>

	<section class="demo__group">
		<Heading level={3} size="sm" tone="muted">Sizes</Heading>
		<Grid minColWidth="13rem" gap={5} align="start">
			<FormGroup label="Small" description="size=sm" for="fg-s" size="sm">
				<input id="fg-s" class="xoji-control" type="text" value="sm" />
			</FormGroup>
			<FormGroup label="Medium" description="size=md" for="fg-m" size="md">
				<input id="fg-m" class="xoji-control" type="text" value="md" />
			</FormGroup>
			<FormGroup label="Large" description="size=lg" for="fg-l" size="lg">
				<input id="fg-l" class="xoji-control" type="text" value="lg" />
			</FormGroup>
		</Grid>
	</section>
</Stack>

<style>
	.demo {
		width: 100%;
	}
	.demo__group {
		display: grid;
		gap: var(--space-3);
	}
</style>
